{
  "name": "zvb-site",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "check:astro": "astro check",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/svelte": "^7.0.10",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.0.17",
    "astro": "^5.13.0",
    "svelte": "^5.36.0",
    "tailwindcss": "^4.0.17",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte-check": "^4.3.3",
    "typescript-eslint": "^8.43.0"
  }
}
