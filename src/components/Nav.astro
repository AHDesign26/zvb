---
import site from '../content/site.json';
import MobileNav from './MobileNav.svelte';

interface Props {
  activeHref?: string;
}

const { activeHref } = Astro.props;

const isActive = (href: string): boolean => {
  if (!activeHref) return false;
  if (href === activeHref) return true;
  if (href.startsWith('/') && activeHref.startsWith(href) && href !== '/') return true;
  return false;
};
---

<nav
  class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b-[0.5px] border-indigo-200/30 shadow-sm transition-all"
>
  <div
    class="flex justify-between items-center px-6 md:px-8 h-20 w-full max-w-screen-2xl mx-auto relative"
  >
    <a href="/" aria-label={site.company}>
      <img
        src={site.logo}
        alt={`${site.company} logo`}
        class="h-16 w-auto"
        width="120"
        height="64"
      />
    </a>
    <div class="hidden md:flex items-center gap-10">
      {
        site.nav.map((item) => (
          <a
            class:list={[
              'desktop-nav-link border-b-2 pb-1 font-medium transition-colors duration-300',
              "font-['Inter']",
              isActive(item.href)
                ? 'text-indigo-900 border-secondary hover:text-secondary/80'
                : 'text-slate-600 border-transparent hover:text-secondary',
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center gap-4">
      <a
        href={site.phoneHref}
        class="hidden md:flex items-center gap-2 text-slate-600 font-['Inter'] font-medium hover:text-secondary transition-colors duration-300"
      >
        <span class="material-symbols-outlined text-xl" translate="no">call</span>
        <span>{site.phone}</span>
      </a>
      <a
        href={site.ctaHref}
        class="hidden sm:block bg-primary text-white px-6 py-3 rounded-lg font-label font-bold text-sm hover:bg-primary/90 transition-all active:scale-95 relative overflow-hidden group"
      >
        <span class="relative z-10">{site.ctaLabel}</span>
        <div
          class="absolute inset-0 bg-secondary translate-y-full group-hover:translate-y-0 transition-transform duration-300"
        >
        </div>
      </a>
      <MobileNav
        client:load
        items={site.nav}
        phone={site.phone}
        phoneHref={site.phoneHref}
        ctaLabel={site.ctaLabel}
        ctaHref={site.ctaHref}
      />
    </div>
  </div>
</nav>
