---
import site from '../content/site.json';

interface Props {
  title: string;
  description: string;
  badges: string[];
  callLabel: string;
  quoteLabel: string;
}

const { title, description, badges, callLabel, quoteLabel } = Astro.props;
---

<section class="py-20 px-4 sm:px-8 md:px-12 bg-primary relative overflow-hidden text-center">
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div
      class="absolute top-0 left-1/4 h-full w-[1px] signal-v text-white"
      style="animation-duration: 8s;"
    >
    </div>
    <div
      class="absolute top-0 right-1/4 h-full w-[1px] signal-v text-[#FFC107]"
      style="animation-duration: 10s; animation-delay: -3s;"
    >
    </div>
    <div
      class="absolute top-1/2 left-0 w-full h-[1px] signal-h text-white"
      style="animation-duration: 15s;"
    >
    </div>
  </div>
  <div class="max-w-4xl mx-auto relative z-10 reveal-on-scroll">
    <h2 class="font-headline text-3xl md:text-4xl font-bold text-white mb-6">{title}</h2>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 mb-6">
      {
        badges.map((badge, i) => (
          <>
            {i > 0 && <span class="hidden sm:block w-[1px] h-4 bg-white/30" />}
            <span class="inline-flex items-center gap-2 text-white text-sm font-label font-semibold">
              <svg
                style="width:1rem;height:1rem;flex-shrink:0;color:#FFC107;"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span style="text-decoration:underline;text-decoration-color:#FFC107;text-underline-offset:4px;text-decoration-thickness:2px;font-size:1.125rem;color:#FFC107;">
                {badge}
              </span>
            </span>
          </>
        ))
      }
    </div>
    <p class="text-indigo-100 text-lg mb-10 opacity-80 leading-relaxed max-w-xl mx-auto">
      {description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={site.phoneHref}
        class="bg-secondary text-primary px-8 py-4 rounded-xl font-label font-bold text-xs uppercase tracking-widest hover:brightness-110 transition-all shadow-xl"
      >
        {callLabel}
      </a>
      <a
        href={site.ctaHref}
        class="border border-white/30 text-white px-8 py-4 rounded-xl font-label font-bold text-xs uppercase tracking-widest hover:bg-white/10 transition-colors"
      >
        {quoteLabel}
      </a>
    </div>
  </div>
</section>
