---
// Decorative animated vertical wires pinned to the viewport edges.
---

<div class="fixed left-8 top-0 h-full w-[1px] bg-slate-200/20 z-10 hidden lg:block">
  <div class="wire-trace wire-v wire-trace-amber signal-v text-[#FFC107]"></div>
</div>
<div class="fixed right-8 top-0 h-full w-[1px] bg-slate-200/20 z-10 hidden lg:block">
  <div class="wire-trace wire-v signal-v text-[#1A237E]" style="animation-delay: -2s;"></div>
</div>
