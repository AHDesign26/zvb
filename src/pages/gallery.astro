---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import gallery from '../content/pages/gallery.json';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={gallery.meta.title} description={gallery.meta.description} activeHref="/gallery">
  <!-- Hero -->
  <section
    class="relative flex items-end px-6 md:px-12 pt-40 pb-16 overflow-hidden bg-primary"
    style="min-height:340px;"
  >
    <div class="absolute inset-0 z-0">
      <img
        src={gallery.hero.image}
        alt="Gallery"
        class="object-cover w-full h-full opacity-30"
        width="1920"
        height="1080"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary/40"></div>
    </div>
    <div class="absolute inset-0 z-10 overflow-hidden pointer-events-none opacity-30">
      <div
        class="absolute top-1/3 left-0 w-full h-[1px] signal-h text-[#FFC107]"
        style="animation-duration: 10s;"
      >
      </div>
      <div
        class="absolute top-2/3 left-0 w-full h-[1px] signal-h text-white"
        style="animation-duration: 14s; animation-delay: -4s;"
      >
      </div>
    </div>
    <div class="relative z-20 max-w-7xl mx-auto w-full reveal-on-scroll">
      <span
        class="text-secondary font-label font-bold tracking-widest text-sm uppercase mb-4 block"
      >
        {gallery.hero.eyebrow}
      </span>
      <h1 class="font-headline text-4xl md:text-5xl font-bold text-white mb-4">
        {gallery.hero.title}
      </h1>
      <p class="text-indigo-200 text-lg max-w-xl">{gallery.hero.description}</p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-20 md:py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="flex flex-wrap gap-3 mb-12 reveal-on-scroll" id="filter-bar">
        {
          gallery.filters.map((f, i) => (
            <button
              type="button"
              class:list={['filter-btn', i === 0 && 'active']}
              data-filter={f.key}
            >
              <span class="material-symbols-outlined text-base" translate="no">
                {f.icon}
              </span>
              {f.label}
            </button>
          ))
        }
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery-grid">
        {
          projects.map((project) => (
            <div
              class="gallery-item group relative overflow-hidden rounded-2xl shadow-md hover:shadow-2xl transition-all duration-500 cursor-pointer"
              data-category={project.data.category}
              style="height:300px;"
            >
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
                width="800"
                height="600"
              />
              <div class="absolute inset-0 bg-primary/30 group-hover:bg-primary/10 transition-colors duration-500" />
              <div class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-primary via-primary/60 to-transparent translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                <span class="text-secondary font-label text-[10px] uppercase tracking-widest font-bold mb-1 block">
                  {project.data.categoryLabel}
                </span>
                <h4 class="text-white font-headline text-lg font-bold">{project.data.title}</h4>
              </div>
            </div>
          ))
        }
      </div>

      <div id="no-results" class="hidden text-center py-24">
        <span class="material-symbols-outlined text-6xl text-slate-300 mb-4 block" translate="no"
          >image_search</span
        >
        <p class="text-on-surface-variant text-lg">{gallery.emptyStateText}</p>
      </div>
    </div>
  </section>

  <script>
    const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
    const galleryItems = document.querySelectorAll<HTMLElement>('.gallery-item');
    const noResults = document.getElementById('no-results');

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.dataset.filter ?? 'all';
        let visibleCount = 0;

        galleryItems.forEach((item) => {
          if (filter === 'all' || item.dataset.category === filter) {
            item.classList.remove('hidden-item');
            item.style.position = '';
            item.style.visibility = '';
            visibleCount += 1;
          } else {
            item.classList.add('hidden-item');
          }
        });

        if (noResults) {
          noResults.classList.toggle('hidden', visibleCount > 0);
        }
      });
    });
  </script>
</BaseLayout>
